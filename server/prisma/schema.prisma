generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ingredient {
  id             String                @id @default(uuid())
  name           String                @unique
  sizeOz         Float
  groceryCost    Float
  perishableDays Int?

  inventoryItems InventoryIngredient[]
  recipeIngredients RecipeIngredient[]
}

model InventoryIngredient {
  id           String     @id @default(uuid())
  ingredientId String
  quantity     Int        @default(1)
  daysOld      Int        @default(0)

  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
}

model Cup {
  id             String                @id @default(uuid())
  name           String                @unique
  sizeOz         Float
  groceryCost    Float

  inventoryItems InventoryCup[]
}

model InventoryCup {
  id           String     @id @default(uuid())
  cupId String
  quantity     Int        @default(1)

  cup   Cup @relation(fields: [cupId], references: [id])
}

model Recipe {
  id           String     @id @default(uuid())
  name           String                @unique
  dayUnlocked Int

  ingredients RecipeIngredient[]
}

model RecipeIngredient {
  id           String     @id @default(uuid())
  recipeId String
  ingredientId String
  amountOz         Float

  recipe Recipe @relation(fields: [recipeId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
}